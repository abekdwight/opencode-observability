{
  "$schema": "https://biomejs.dev/schemas/2.4.8/schema.json",
  "files": {
    "includes": [
      "**",
      "!dist",
      "!node_modules",
      "!playwright-report",
      "!test-results",
      "!.sisyphus",
      "tests/**/*.ts",
      "e2e/**/*.ts",
      "web/**/*.ts",
      "web/**/*.css",
      "web/**/*.html",
      "tsconfig*.json",
      "vite.config.ts",
      "vitest.config.ts",
      "playwright.config.ts",
      "*.json",
      "*.md",
      ".github/**/*.yml"
    ]
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["web/pages/SessionDetail.tsx"],
      "linter": {
        "rules": {
          "security": {
            "noDangerouslySetInnerHtml": "off"
          }
        }
      }
    }
  ]
}
